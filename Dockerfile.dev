FROM node:22-alpine
 
# Install build tools untuk native modules (better-sqlite3, sharp, dll)
RUN apk add --no-cache python3 make g++
 
# Install pnpm
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
 
# Set working directory
WORKDIR /app
 
# Copy package files
COPY package.json pnpm-lock.yaml* .npmrc* ./
 
# Removed pnpm-workspace.yaml copy
 
# Install dependencies — izinkan semua build scripts
RUN pnpm config set ignore-scripts false && pnpm install --frozen-lockfile
 
# Copy source code
COPY . .
 
# Expose port
EXPOSE 3000
 
# Start dev server
CMD ["pnpm", "dev"]
 